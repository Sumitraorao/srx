rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profile Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'first_name', 'last_name', 'role', 'createdAt', 'updatedAt']) &&
             data.keys().size() <= 7 && // Including optional phone_number
             data.email is string && data.email.size() <= 128 &&
             data.first_name is string && data.first_name.size() <= 64 &&
             data.last_name is string && data.last_name.size() <= 64 &&
             (data.role == 'user' || data.role == 'admin') &&
             (!('phone_number' in data) || (data.phone_number is string && data.phone_number.size() <= 20));
    }

    match /users/{userId} {
      // Identity Poisoning Guard & Ownership
      allow get: if isOwner(userId) && isValidId(userId);
      
      allow create: if isOwner(userId) && isValidId(userId) &&
                       isValidUser(incoming()) &&
                       incoming().role == 'user' &&
                       incoming().email == request.auth.token.email &&
                       incoming().createdAt == request.time &&
                       incoming().updatedAt == request.time;

      allow update: if isOwner(userId) && isValidId(userId) &&
                       isValidUser(incoming()) &&
                       incoming().email == existing().email &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().updatedAt == request.time &&
                       // Prevent self-role escalation
                       incoming().role == existing().role;
      
      allow delete: if false; // Users cannot delete their profiles for audit trails
    }
  }
}
